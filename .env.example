# Docker Hub credentials
DOCKERHUB_USERNAME=your-dockerhub-username

# Admin credentials (CHANGE THESE!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123!

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# SMTP settings for password reset emails (optional but recommended)
# Leave SMTP_HOST empty to disable email sending (password reset won't work)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=GuestAccess
SMTP_ENABLE_SSL=true

# Home Assistant webhook integration
# Each command gets its own webhook path and secret token for isolation
HA_BASE_URL=https://your-ha-instance.duckdns.org
HA_CANCELLO_WEBHOOK_PATH=your-cancello-webhook-id
HA_CANCELLO_SECRET_TOKEN=your-cancello-secret
HA_CANCELLETTO_WEBHOOK_PATH=your-cancelletto-webhook-id
HA_CANCELLETTO_SECRET_TOKEN=your-cancelletto-secret
HA_PORTONE_WEBHOOK_PATH=your-portone-webhook-id
HA_PORTONE_SECRET_TOKEN=your-portone-secret
