@page
@model LogsModel
@{
    ViewData["Title"] = "My Activity Logs";
}

<h1>My Activity Logs</h1>
<p class="lead">Your activity history for the last 30 days</p>

@if (Model.Logs.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Date & Time</th>
                    <th>Action</th>
                    <th>Details</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.Logs)
                {
                    <tr>
                        <td>
                            <span class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span>
                            <small class="text-muted d-block">@log.Timestamp.ToLocalTime().ToString("dddd")</small>
                        </td>
                        <td>
                            @if (log.Action.Contains("Login"))
                            {
                                <span class="badge bg-success">@log.Action</span>
                            }
                            else if (log.Action.Contains("Logout"))
                            {
                                <span class="badge bg-secondary">@log.Action</span>
                            }
                            else if (log.Action.Contains("Apri"))
                            {
                                <span class="badge bg-primary">@log.Action</span>
                            }
                            else
                            {
                                <span class="badge bg-info">@log.Action</span>
                            }
                        </td>
                        <td>@(log.Details ?? "-")</td>
                        <td><small class="text-muted">@log.IpAddress</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="alert alert-info mt-4">
        <i class="bi bi-info-circle"></i>
        <strong>Note:</strong> Logs are automatically deleted after 30 days.
        Total records: <strong>@Model.Logs.Count</strong>
    </div>
}
else
{
    <div class="alert alert-warning">
        <h4 class="alert-heading">No Activity Yet</h4>
        <p>You don't have any logged activity in the last 30 days.</p>
    </div>
}

<div class="mt-3">
    <a asp-page="/Index" class="btn btn-secondary">Back to Home</a>
</div>
