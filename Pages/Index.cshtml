@page
@model IndexModel
@{
    ViewData["Title"] = "Controllo Accessi";
}

<div class="text-center">
    <h1 class="display-4">Controllo Accessi</h1>
    <p class="lead">Benvenuto @Model.UserEmail</p>
</div>

@if (!Model.HasAnyPermission)
{
    <div class="alert alert-warning mt-4" role="alert">
        <h4 class="alert-heading">Nessun permesso assegnato</h4>
        <p>Il tuo account non ha permessi per controllare nessun accesso. Contatta l'amministratore per richiedere i permessi necessari.</p>
    </div>
}
else
{
    <div class="row mt-5 justify-content-center">
        @if (Model.CanOpenCancello)
        {
            <div class="col-md-4 mb-3">
                <form method="post" asp-page-handler="OpenCancello">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary btn-lg w-100 py-4">
                        <i class="bi bi-door-open"></i><br/>
                        Apri Cancello
                    </button>
                </form>
            </div>
        }

        @if (Model.CanOpenCancelletto)
        {
            <div class="col-md-4 mb-3">
                <form method="post" asp-page-handler="OpenCancelletto">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success btn-lg w-100 py-4">
                        <i class="bi bi-door-open"></i><br/>
                        Apri Cancelletto
                    </button>
                </form>
            </div>
        }

        @if (Model.CanOpenPortone)
        {
            <div class="col-md-4 mb-3">
                <form method="post" asp-page-handler="OpenPortone">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-info btn-lg w-100 py-4">
                        <i class="bi bi-door-open"></i><br/>
                        Apri Portone
                    </button>
                </form>
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(Model.Message))
    {
        <div class="alert alert-success mt-4" role="alert">
            <i class="bi bi-check-circle"></i> @Model.Message
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger mt-4" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @Model.ErrorMessage
        </div>
    }
}
